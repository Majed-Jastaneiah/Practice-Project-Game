# Copy this file to .env and fill in your values.
# Never commit .env to Git.

# ── Firebase (required) ──────────────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── Google OAuth (required for Google Sign In) ───────────────────────────────
# Create OAuth 2.0 credentials in Google Cloud Console.
# Web Client ID is used by expo-auth-session on both platforms.
# iOS and Android Client IDs are used for native sign-in flows via EAS builds.
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=

# ── Facebook OAuth (required for Facebook Sign In) ───────────────────────────
# Create an app at https://developers.facebook.com
EXPO_PUBLIC_FACEBOOK_APP_ID=

# ── Expo (required for OAuth redirect in development) ────────────────────────
# Your Expo username — used to construct the redirect URI.
EXPO_PUBLIC_OWNER=your-expo-username
